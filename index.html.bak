<!DOCTYPE html>
<html lang="uz">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HUD Code Editor Pro</title>

<!-- CodeMirror CSS -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/theme/material-darker.min.css">

<style>
body{
  margin:0;
  height:100vh;
  display:flex;
  flex-direction:column;
  background:#0d0d0d;
  font-family:Arial;
}

/* TOP BAR */
.toolbar{
  height:45px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:0 10px;
  background:linear-gradient(90deg,#111,#1c1c1c);
  border-bottom:1px solid #333;
  box-shadow:0 0 15px #00ffcc33;
}

.logo{
  color:#00ffcc;
  font-weight:bold;
  letter-spacing:1px;
}

.btn{
  background:#1f1f1f;
  border:1px solid #333;
  color:#00ffcc;
  padding:6px 10px;
  margin-left:5px;
  border-radius:6px;
  cursor:pointer;
  transition:0.2s;
}

.btn:hover{
  background:#00ffcc;
  color:black;
  box-shadow:0 0 10px #00ffcc;
}

/* OUTPUT */
iframe{
  width:100%;
  height:45%;
  border:none;
  background:white;
}

/* EDITOR */
.editor{
  height:calc(55% - 45px);
}

.CodeMirror{
  height:100% !important;
  font-size:14px;
}
</style>
</head>

<body>

<!-- TOOLBAR -->
<div class="toolbar">
  <div class="logo">⚡ HUD EDITOR PRO</div>
  <div>
    <button class="btn" onclick="runCode()">▶ Run</button>
    <button class="btn" onclick="clearCode()">🧹 Clear</button>
    <button class="btn" onclick="pasteCode()">📋 Paste</button>
  </div>
</div>

<!-- OUTPUT -->
<iframe id="output"></iframe>

<!-- EDITOR -->
<div class="editor">
<textarea id="code">
<!DOCTYPE html>
<html>
<head>
<style>
body{
  background:black;
  color:white;
  text-align:center;
}
h1{
  color:#00ffcc;
}
</style>
</head>
<body>

<h1>Taiman coder</h1>
<p>Syntax highlight + live preview</p>

<script>
console.log("Hello HUD Editor");
</script>

</body>
</html>
</textarea>
</div>

<!-- CODEMIRROR -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/htmlmixed/htmlmixed.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/xml/xml.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/javascript/javascript.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/mode/css/css.min.js"></script>

<script>
const editor = CodeMirror.fromTextArea(document.getElementById("code"),{
  mode:"htmlmixed",
  theme:"material-darker",
  lineNumbers:true,
  tabSize:2
});

const output = document.getElementById("output");

/* ▶ RUN */
function runCode(){
  output.srcdoc = editor.getValue();
}

/* 🧹 CLEAR */
function clearCode(){
  editor.setValue("");
  runCode();
}

/* 📋 PASTE */
async function pasteCode(){
  try{
    const text = await navigator.clipboard.readText();
    editor.setValue(text);
    runCode();
  }catch(e){
    alert("Clipboard ruxsat berilmagan!");
  }
}

/* REALTIME */
editor.on("change",runCode);
runCode();
</script>

</body>
</html>